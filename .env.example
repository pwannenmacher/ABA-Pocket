# Server
LISTEN_ADDR=:8080

# Database
POSTGRES_DB=aba_pocket
POSTGRES_USER=aba
POSTGRES_PASSWORD=change-this-password

# Session secret (min 32 characters, change this!)
SESSION_SECRET=change-this-to-a-random-32-char-secret!!

# Initial admin account (only used on first start if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Development mode (disables template caching)
DEV_MODE=false

# Trusted reverse proxies (comma-separated CIDRs/IPs)
# When set, X-Forwarded-For from these IPs is used as the real client IP in logs.
# Example: TRUSTED_PROXIES=172.18.0.0/16,10.0.0.0/8
TRUSTED_PROXIES=

# Imprint / legal notice (§ 5 DDG)
IMPRINT_NAME="Max Mustermann"
IMPRINT_STREET="c/o Musterservice, Musterstraße 1"
IMPRINT_ZIP=12345
IMPRINT_CITY=Musterstadt
IMPRINT_EMAIL=kontakt@example.de

